rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helpers
    // ----------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Fetches the caller's user document. Only call after isSignedIn().
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Any member of the org (admin | editor | viewer).
    function isMember(orgId) {
      return isSignedIn()
        && request.auth.token.screen != true
        && userDoc().orgId == orgId;
    }

    // Editor or admin — can create/edit content.
    function isEditor(orgId) {
      return isMember(orgId) && userDoc().role in ['admin', 'editor'];
    }

    // Admin only — billing, team management, destructive ops.
    function isAdmin(orgId) {
      return isMember(orgId) && userDoc().role == 'admin';
    }

    // Display screen custom tokens are issued by api/screen-token.js after the
    // browser proves possession of the pairing-time screen secret.
    function isScreenToken(screenId) {
      return isSignedIn()
        && request.auth.token.screen == true
        && request.auth.token.screenId == screenId;
    }

    function isScreenTokenForOrg(orgId, screenId) {
      return isScreenToken(screenId)
        && request.auth.token.orgId == orgId;
    }

    function isOrgScreenToken(orgId) {
      return isSignedIn()
        && request.auth.token.screen == true
        && request.auth.token.orgId == orgId;
    }

    function canReadPublishedSlideshow(orgId) {
      return isMember(orgId) || isOrgScreenToken(orgId);
    }

    function slideshowOrg(showId) {
      return get(/databases/$(database)/documents/slideshows/$(showId)).data.orgId;
    }

    // ----------------------------------------------------------------
    // users/{uid}
    // Users can only read and write their own document.
    // Server-side admin SDK (screen-monitor, stripe-webhook) bypasses rules.
    // ----------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ----------------------------------------------------------------
    // organizations/{orgId}
    // ----------------------------------------------------------------
    match /organizations/{orgId} {
      allow read: if isMember(orgId);

      // Organization creation is handled by /api/link-account so the server
      // controls subscription defaults, owner metadata, and initial membership.
      allow create: if false;

      // Organization settings, membership, and subscription changes are handled
      // by server APIs. The only browser-writeable org field is a short-lived
      // screen limit enforcement lease used to dedupe concurrent admin tabs.
      allow update: if isAdmin(orgId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'screenLimitEnforcement'
        ]);

      allow delete: if false;

      // -- Media library --
      match /media/{mediaId} {
        allow read: if isMember(orgId);
        allow create, update: if isEditor(orgId);
        allow delete: if isEditor(orgId);
      }

      // -- Analytics events --
      // Paired displays write with a Firebase custom screen token.
      match /analytics/{eventId} {
        allow read: if isMember(orgId);
        allow create: if request.resource.data.screenId is string
          && isScreenTokenForOrg(orgId, request.resource.data.screenId);
        allow update, delete: if false;
      }

      // -- Schedules --
      // display.html reads schedules without auth to determine which
      // slideshow to play at a given time.
      match /schedules/{scheduleId} {
        allow read: if true;
        allow create, update: if isEditor(orgId);
        allow delete: if isEditor(orgId);
      }
    }

    // ----------------------------------------------------------------
    // screens/{screenId}
    // display.html runs on TV hardware:
    //   - needs read access to its own screen doc (slideshowId, settings)
    //   - credentialed screens write lastSeen with a Firebase custom screen token
    // Admins/editors create and manage screen docs during the pairing flow.
    // ----------------------------------------------------------------
    match /screens/{screenId} {
      // Public read — display.html has no authenticated user.
      allow read: if true;

      // Only authenticated editors/admins can create a screen doc during pairing.
      // New screens must carry only the hash of the display's local secret.
      allow create: if isEditor(request.resource.data.orgId)
        && request.resource.data.credentialHash is string
        && request.resource.data.credentialHash.matches('^[a-f0-9]{64}$')
        && request.resource.data.credentialVersion == 1;

      // Two cases:
      //   1. Credentialed display heartbeat — only lastSeen may change.
      //   2. Authenticated editor/admin — full update for their org's screen.
      allow update: if
        (
          isScreenToken(screenId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen'])
        )
        || isEditor(resource.data.orgId);

      // Only admins can delete screens.
      allow delete: if isAdmin(resource.data.orgId);
    }

    // ----------------------------------------------------------------
    // pairingCodes/{code}
    // Pairing flow:
    //   1. display.html creates a code (no auth) with status "pending".
    //   2. display.html polls for status changes (no auth).
    //   3. Admin reads the code, creates the screen doc, then updates
    //      the code to status "paired".
    // ----------------------------------------------------------------
    match /pairingCodes/{code} {
      // Public read — display polls for the admin to complete pairing.
      allow read: if true;

      // display.html creates codes without auth. The raw screen secret never
      // leaves localStorage; only its SHA-256 hash is stored for admin pairing.
      allow create: if
        request.resource.data.status == 'pending'
        && request.resource.data.credentialVersion == 1
        && request.resource.data.screenCredentialHash is string
        && request.resource.data.screenCredentialHash.matches('^[a-f0-9]{64}$')
        && request.resource.data.keys().hasOnly([
          'status',
          'createdAt',
          'expiresAt',
          'screenCredentialHash',
          'credentialVersion'
        ]);

      // Only authenticated users can mark a code as paired.
      // Prevent replaying or overwriting already-paired codes.
      allow update: if
        isSignedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == 'paired'
        && request.resource.data.screenId is string
        && exists(/databases/$(database)/documents/screens/$(request.resource.data.screenId))
        && isEditor(get(/databases/$(database)/documents/screens/$(request.resource.data.screenId)).data.orgId);

      allow delete: if false;
    }

    // ----------------------------------------------------------------
    // slideshows/{showId}
    // Admin previews read with the signed-in user's auth state.
    // Paired displays read with a Firebase custom screen token.
    // Admins and editors can create/edit slideshows.
    // ----------------------------------------------------------------
    match /slideshows/{showId} {
      allow read: if canReadPublishedSlideshow(resource.data.orgId);

      allow create: if isEditor(request.resource.data.orgId);
      allow update: if isEditor(resource.data.orgId);
      allow delete: if isAdmin(resource.data.orgId);

      // -- Published slides --
      // display.html renders published slides with either user auth
      // (admin preview) or a credentialed screen token.
      match /slides/{slideId} {
        allow read: if canReadPublishedSlideshow(slideshowOrg(showId));
        allow create, update: if isEditor(
          get(/databases/$(database)/documents/slideshows/$(showId)).data.orgId
        );
        allow delete: if isEditor(
          get(/databases/$(database)/documents/slideshows/$(showId)).data.orgId
        );
      }

      // -- Draft slides --
      // Drafts are not public; only org editors/admins can read/write them.
      match /draftSlides/{slideId} {
        allow read, create, update, delete: if isEditor(
          get(/databases/$(database)/documents/slideshows/$(showId)).data.orgId
        );
      }

      // -- Slide version history --
      // Versions are append-only (no updates or deletes).
      match /slideVersions/{slideId}/versions/{versionId} {
        allow read: if isMember(
          get(/databases/$(database)/documents/slideshows/$(showId)).data.orgId
        );
        allow create: if isEditor(
          get(/databases/$(database)/documents/slideshows/$(showId)).data.orgId
        );
        allow update, delete: if false;
      }
    }

    // ----------------------------------------------------------------
    // broadcasts/{orgId}
    // display.html reads broadcasts without auth (emergency messaging).
    // Only admins can create or deactivate broadcasts.
    // ----------------------------------------------------------------
    match /broadcasts/{orgId} {
      allow read: if true;
      allow write: if isAdmin(orgId);
    }

    // ----------------------------------------------------------------
    // capAlerts/{orgId}
    // display.html reads CAP mirrors without user auth. The poller/test
    // helpers write with Admin SDK; direct client writes stay admin-only.
    // ----------------------------------------------------------------
    match /capAlerts/{orgId} {
      allow read: if true;
      allow write: if isAdmin(orgId);
    }

    // ----------------------------------------------------------------
    // brandKits/{orgId}
    // ----------------------------------------------------------------
    match /brandKits/{orgId} {
      allow read: if isMember(orgId);
      allow write: if isAdmin(orgId);
    }

    // ----------------------------------------------------------------
    // invitations/{inviteId}
    // Admins create invitations; invitees read and accept their own.
    // Invitee is matched by verified email from the Firebase Auth token.
    // ----------------------------------------------------------------
    match /invitations/{inviteId} {
      allow read: if isSignedIn() && (
        isAdmin(resource.data.orgId)
        || request.auth.token.email == resource.data.email
      );

      // Only admins can invite new members.
      allow create: if isAdmin(request.resource.data.orgId);

      // Admins can cancel; invitees can accept their own invitation.
      allow update: if isSignedIn() && (
        isAdmin(resource.data.orgId)
        || request.auth.token.email == resource.data.email
      );

      allow delete: if false;
    }

    // ----------------------------------------------------------------
    // pending_subscriptions — populated by marketing site, consumed by
    // stripe-webhook.js via admin SDK. Block all client access.
    // ----------------------------------------------------------------
    match /pending_subscriptions/{docId} {
      allow read, write: if false;
    }
  }
}
